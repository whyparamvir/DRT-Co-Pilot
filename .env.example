# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Optional: point to the sibling Ciucci-lab pyDRTtools install.
# If unset, backend tries ../pyDRT/.venv/Lib/site-packages and normal Python imports.
PYDRTTOOLS_SITE_PACKAGES=../pyDRT/.venv/Lib/site-packages

# Default AI provider: mock | openai | gemini | anthropic | openai-compatible
# (Users can also connect a provider/model/key in-app; these env vars are only the fallback.)
AI_PROVIDER=mock
AI_MODEL=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
